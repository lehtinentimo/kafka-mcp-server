{
  "name": "kafka-mcp-server",
  "version": "1.0.0",
  "description": "Kafka MCP Server",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "kafka-mcp-server": "dist/index.js"
  },
  "engines": {
    "node": "^18.18.0 || ^20.9.0 || >=21.1.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.ts' '*.js' '*.json'",
    "format:check": "prettier --check 'src/**/*.ts' '*.js' '*.json'"
  },
  "dependencies": {
    "@confluentinc/kafka-javascript": "^1.8.2",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.0.18"
  }
}
